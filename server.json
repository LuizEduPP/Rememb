{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.luizedupp/rememb",
  "description": "Persistent memory for AI agents — local JSON file, zero config, no server required. Works with Cursor, Windsurf, Claude, and any MCP-compatible IDE.",
  "repository": {
    "url": "https://github.com/LuizEduPP/Rememb",
    "source": "github"
  },
  "version": "0.3.3",
  "packages": [
    {
      "registry_type": "pypi",
      "identifier": "rememb",
      "version": "0.3.3",
      "transport": {
        "type": "stdio"
      },
      "installation": {
        "type": "pip",
        "package": "rememb[mcp]"
      },
      "command": "rememb",
      "args": ["mcp"]
    }
  ]
}
